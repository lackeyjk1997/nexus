{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "/usr/local/bin/corepack",
      "runtimeArgs": ["pnpm", "--filter", "@nexus/web", "dev"],
      "port": 3001,
      "autoPort": true,
      "env": {
        "COREPACK_HOME": "/tmp/corepack",
        "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  ]
}
